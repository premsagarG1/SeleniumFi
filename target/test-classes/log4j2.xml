<?xml version="1.0" encoding="UTF-8"?>
<Configuration monitorinterval="30" status="info" >


    <Properties>
        <Property name="basPath">./log</Property>
    </Properties>
    
    
    <Appenders>
    
        <Console name="File" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss:SSS} [%] %-5level %-logger{36} %msg%n" />
        </Console>
        
        
        <RollingFile name="File" fileName="${basPath}/automation.log" filePattern="${basPath}/automation.lo-_%d{yyyy-MM-dd}.log">
            <PatternLayout  pattern="%d{HH:mm:ss:SSS} [%] %-5level %-logger{36} %msg%n"  />

               
                <TimeBasedTriggeringPolicy size="5000"/>
           
        </RollingFile>
        
    </Appenders>
    
    <Loggers>
        <Root level="info">
            <AppenderRef ref="File" />
           <!-- <AppenderRef ref="Console" />-->
            
        </Root>
    </Loggers>
    
</Configuration>